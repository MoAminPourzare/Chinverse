# Local development
ENVIRONMENT=local
DEBUG=false
PROJECT_NAME=ChinVerse API

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chinverse_db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE_SECONDS=1800

SECRET_KEY=replace-this-with-a-generated-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_DEFAULT_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_WRITE_REQUESTS=60
RATE_LIMIT_WRITE_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_REQUESTS=20
RATE_LIMIT_UPLOAD_WINDOW_SECONDS=300

MAX_IMAGE_UPLOAD_SIZE_BYTES=5242880
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp
ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp
MAX_VIDEO_UPLOAD_SIZE_BYTES=524288000
ALLOWED_VIDEO_EXTENSIONS=mp4,webm,mov,m4v
ALLOWED_VIDEO_CONTENT_TYPES=video/mp4,video/webm,video/quicktime,video/x-m4v
FILE_STORAGE_MODE=local

BACKEND_CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=*

ENABLE_API_DOCS=true
SECURE_HEADERS_ENABLED=true
HSTS_ENABLED=false

ADMIN_EMAILS=

# Production example
# ENVIRONMENT=production
# DATABASE_URL=postgresql://app_user:strong_password@db-host:5432/chinverse_db
# SECRET_KEY=generate-with-python-secrets-token-urlsafe
# BACKEND_CORS_ORIGINS=https://your-frontend-domain.com
# ALLOWED_HOSTS=your-api-domain.com
# ENABLE_API_DOCS=false
# HSTS_ENABLED=true
